# Database
DATABASE_URL="postgresql://codematrix:codematrix-password@localhost:5432/codematrix?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-jwt-secret-change-in-production"

# AI Configuration
# Provider: "anthropic" or "openai-compatible"
# "openai-compatible" works with: OpenAI, DeepSeek, Moonshot (Kimi), Qwen, Ollama, etc.
AI_PROVIDER="openai-compatible"
AI_API_KEY="your-api-key-here"
AI_MODEL="gpt-4o"
AI_BASE_URL="https://api.openai.com/v1"
AI_MAX_TOKENS=8192
AI_TEMPERATURE=0.7

# --- Provider Examples ---
# OpenAI:       AI_PROVIDER="openai-compatible"  AI_BASE_URL="https://api.openai.com/v1"        AI_MODEL="gpt-4o"
# DeepSeek:     AI_PROVIDER="openai-compatible"  AI_BASE_URL="https://api.deepseek.com/v1"      AI_MODEL="deepseek-chat"
# Moonshot:     AI_PROVIDER="openai-compatible"  AI_BASE_URL="https://api.moonshot.cn/v1"       AI_MODEL="moonshot-v1-128k"
# Qwen (China): AI_PROVIDER="openai-compatible"  AI_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"  AI_MODEL="qwen-max"
# Ollama:       AI_PROVIDER="openai-compatible"  AI_BASE_URL="http://localhost:11434/v1"         AI_MODEL="llama3"
# Anthropic:    AI_PROVIDER="anthropic"           AI_API_KEY="sk-ant-..."                        AI_MODEL="claude-sonnet-4-20250514"

# Server
PORT=3001
NODE_ENV=development