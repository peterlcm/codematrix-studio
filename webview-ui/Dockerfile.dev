# Development Dockerfile
FROM node:20-bookworm

WORKDIR /app

# Install system dependencies for native modules (esbuild)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libssl3 \
    libffi8 \
    libncurses6 \
    pkg-config \
    python3 \
    make \
    g++ \
    && rm -rf /var/lib/apt/lists/*

# Install pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

# Use npm registry mirror
RUN npm config set registry https://registry.npmmirror.com

# Copy package.json
COPY package.json ./

# Install with ignore scripts to avoid build failures, then rebuild native deps
RUN pnpm install --ignore-scripts && pnpm rebuild

# Copy source code
COPY . .

# Expose ports (Vite dev server + HMR)
EXPOSE 5173 5174

# Start with hot reload
CMD ["pnpm", "dev"]