# CodeMatrix Studio Environment Variables
# Copy this file to .env and update the values

# ===========================================
# Database Configuration
# ===========================================
POSTGRES_USER=codematrix
POSTGRES_PASSWORD=change-this-password-in-production
POSTGRES_DB=codematrix
POSTGRES_PORT=5432

# ===========================================
# Redis Configuration
# ===========================================
REDIS_PORT=6379

# ===========================================
# Application Configuration
# ===========================================
NODE_ENV=development
TZ=UTC

# ===========================================
# Backend Configuration
# ===========================================
JWT_SECRET=change-this-secret-in-production
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ===========================================
# Ports
# ===========================================
HTTP_PORT=80
HTTPS_PORT=443

# ===========================================
# Production URLs (for production deployment)
# ===========================================
DATABASE_URL=postgresql://codematrix:password@postgres:5432/codematrix
REDIS_URL=redis://redis:6379
API_URL=https://your-domain.com
WS_URL=wss://your-domain.com
LOG_LEVEL=info